    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.4",
